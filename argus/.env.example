# ── DigitalOcean Gradient ───────────────────────────────────────────────────
DO_GRADIENT_MODEL_KEY=       # Model Access Key from Gradient AI Platform → Settings
DIGITALOCEAN_API_TOKEN=      # Personal Access Token (genai CRUD + project read)
ADK_AGENT_URL=               # https://agents.do-ai.run/v1/{workspace}/production/run

# ── SQLite ──────────────────────────────────────────────────────────────────
SQLITE_PATH=./data/argus.db

# ── Internal API security ────────────────────────────────────────────────────
INTERNAL_API_SECRET=         # Random secret shared between Node.js and ADK agent

# ── Evolution API / WhatsApp ──────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE_NAME=argus

# ── AI Fallback Tier ──────────────────────────────────────────────────────────
AI_TIER_MODE=auto
AI_COOLDOWN_BASE_SEC=30
AI_CACHE_TTL_SEC=3600
AI_CACHE_MAX_SIZE=500

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7
